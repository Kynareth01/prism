# Prism Configuration
# Copy this file to .env and fill in your values

# GitHub
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_API_BASE=https://api.github.com

# LLM (MiMo V2.5 Pro)
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=mimo-v2.5-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2

# Prism Settings
PRISM_HOST=0.0.0.0
PRISM_PORT=8080
PRISM_LOG_LEVEL=INFO
PRISM_DEFAULT_MODE=full
PRISM_MAX_DIFF_LINES=5000
PRISM_MAX_COMMENTS=50
PRISM_POST_COMMENTS=true
PRISM_IGNORE_PATTERNS=*.lock,package-lock.json,*.min.js,*.min.css
